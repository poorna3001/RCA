# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=readiness_db
DB_USER=postgres
DB_PASSWORD=root

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-change-this-in-production-2024-06-12

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5001,http://127.0.0.1:3000,http://127.0.0.1:5001

# Logging
LOG_LEVEL=DEBUG
LOG_FILE=rca_app.log

# Data Configuration
CSV_PATH=../data/PO_PRICE_HIGHER_CONTRACT.csv
BATCH_SIZE=100

# Features
ENABLE_ANALYTICS=true
ENABLE_CACHING=true
CACHE_TIMEOUT=300

